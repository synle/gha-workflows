name: build-main

on:
  push:
    branches: [master, main]
  pull_request:
    branches: [master, main]

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  build:
    # https://github.com/synle/workflows/blob/main/.github/workflows/pr-js-yarn-16-v2.yml
    uses: synle/workflows/.github/workflows/pr-js-yarn-16-v2.yml@main
    permissions:
      contents: write
    with:
      os: "ubuntu-latest"
